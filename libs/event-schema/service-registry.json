{
  "services": {
    "payments-api": {
      "team": "payments",
      "tier": "critical",
      "dependsOn": ["postgres-payments", "redis-sessions", "fraud-service"],
      "alertOwner": "payments-oncall@company.com"
    },
    "auth-service": {
      "team": "platform",
      "tier": "critical",
      "dependsOn": ["postgres-auth", "redis-tokens"],
      "alertOwner": "platform-oncall@company.com"
    },
    "notification-worker": {
      "team": "growth",
      "tier": "standard",
